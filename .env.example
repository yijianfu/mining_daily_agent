# Mining Daily Agent — Environment Variables
# Copy this file to .env and fill in your values

# ── LLM Configuration ─────────────────────────────────────────────────────
# 只需配置一个 Provider 即可，Agent 会自动检测
# 支持的 Provider:
#   anthropic | openai | deepseek | qwen | zhipu | moonshot

MODEL_PROVIDER=anthropic
MODEL_NAME=                           # 留空 = 使用 Provider 默认模型

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI GPT (https://platform.openai.com/)
# OPENAI_API_KEY=sk-xxxxx

# DeepSeek (https://platform.deepseek.com/)
# DEEPSEEK_API_KEY=sk-xxxxx

# 通义千问 Qwen (https://dashscope.console.aliyun.com/)
# QWEN_API_KEY=sk-xxxxx

# 智谱 GLM (https://open.bigmodel.cn/)
# ZHIPU_API_KEY=xxxxx.xxxxxxxxxxxxxx

# Moonshot Kimi (https://platform.moonshot.cn/)
# MOONSHOT_API_KEY=sk-xxxxx

# Model 高级参数 (通常不需要修改)
# MODEL_TEMPERATURE=0.3
# MODEL_MAX_TOKENS=4096

# ── MCP Server Configuration ──────────────────────────────────────────────
# Transport mode for agent: "stdio" (local) or "sse" (Docker)
MCP_CLIENT_TRANSPORT=stdio

# SSE URLs (used when MCP_CLIENT_TRANSPORT=sse)
MCP_NEWS_URL=http://localhost:8001/sse
MCP_PDF_URL=http://localhost:8002/sse
MCP_LME_URL=http://localhost:8003/sse

# ── News Server ───────────────────────────────────────────────────────────
# NewsAPI key (optional — RSS feeds work without it)
NEWSAPI_KEY=

# ── Price Server ──────────────────────────────────────────────────────────
# Price data provider: "mock" (default, no key needed) or "itick"
LME_PRICE_PROVIDER=mock
# iTick API key (required when LME_PRICE_PROVIDER=itick)
ITICK_API_KEY=

# ── PDF Server ────────────────────────────────────────────────────────────
# Maximum PDF file size in MB
PDF_MAX_SIZE_MB=50

# ── General ───────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
